# Copiar a .env antes de "docker compose up" (obligatorio: env_file en compose).
# Con Docker: DB_USER=app (la imagen MySQL crea el usuario "app"; no usar root).
# IMPORTANTE: DB_HOST y ENV no deben sobreescribir los defaults de docker-compose
#   cuando uses Docker — ver notas abajo.
DB_USER=app
DB_PASSWORD=your_password_here
# Obligatorio con docker-compose: MySQL root debe tener contraseña DISTINTA a DB_PASSWORD.
# Leak de DB_PASSWORD no debe implicar RCE como root MySQL.
MYSQL_ROOT_PASSWORD=your_root_password_here_different_from_db_password
# DB_HOST: dejar en blanco para Docker (docker-compose usa "tuwayki_mysql" por defecto).
#   Sólo setear si corres el servidor Python directamente SIN Docker (desarrollo nativo).
#   Con Docker, si se pone "localhost" aquí se rompe la conectividad MySQL.
#DB_HOST=localhost
DB_PORT=3306
DB_NAME=sistema_ventas
# REDIS_URL: docker-compose la sobreescribe; sólo necesaria para desarrollo nativo.
#REDIS_URL=redis://localhost:6379/0
# Requerido en producción — redis con requirepass. Generar con: openssl rand -base64 24
REDIS_PASSWORD=CAMBIAR_POR_VALOR_SEGURO
ALLOW_MEMORY_RATE_LIMIT_FALLBACK=1
AUTH_SECRET_KEY=replace_with_random_secret_min_32_chars
# PUBLIC_API_URL: NO setear aquí para Docker con NPM — cada superficie tiene su URL
#   hardcodeada en docker-compose.yml. Sólo se necesita para docker-compose.local.yml
#   o docker-compose.test.yml (que la sobreescriben por servicio).
#PUBLIC_API_URL=http://localhost:3000
# URLs públicas por superficie (producción tuwayki.app). Usadas para enlaces entre landing/sys/admin.
PUBLIC_SITE_URL=https://tuwayki.app
PUBLIC_APP_URL=https://sys.tuwayki.app
PUBLIC_OWNER_URL=https://admin.tuwayki.app
# TUWAYKIFOOD (producto hermano, repo y DB separados) — link para el navegador
PUBLIC_FOOD_URL=http://localhost:3003
# TUWAYKIFOOD — llamadas servidor-a-servidor (registro, Owner Admin). Hoy
# apunta al mismo host que PUBLIC_FOOD_URL, pero son conceptualmente distintas.
FOOD_API_URL=http://localhost:3003
# Debe coincidir con FOOD_ADMIN_API_SECRET del .env de TUWAYKIFOOD
FOOD_ADMIN_API_SECRET=your_shared_admin_secret_here
ENV=prod
TRIAL_ENFORCEMENT=0
TRIAL_DAYS=15
ALLOW_DEFAULT_ADMIN=0
INITIAL_ADMIN_PASSWORD=
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_DIGIT=false
PASSWORD_REQUIRE_SPECIAL=false
RECEIPT_PAPER=80
RECEIPT_WIDTH=
# Owner Backoffice — hash bcrypt de la contraseña del admin owner.
# Generar con: python -c "import bcrypt; print(bcrypt.hashpw(b'TU_CLAVE', bcrypt.gensalt(12)).decode())"
# Si no se configura, el sistema usa un hash de respaldo temporal (ver logs).
# IMPORTANTE para Docker: el hash bcrypt contiene '$' — envolver en comillas simples para evitar
# que Docker Compose interpole las variables ($12, $salt, etc.) y corrompa el hash.
# Ejemplo correcto en .env:
#   INTERNAL_ADMIN_CREDENTIALS='usuario:$2b$12$xxxSALTxxxHASHxxx'
OWNER_ADMIN_PASSWORD_HASH=
# ── Facturación Electrónica (credenciales de plataforma) ──
# Token de apis.net.pe para consulta RUC/DNI (un token para todos los tenants).
# Obtener en: https://apis.net.pe/api-consulta-ruc
LOOKUP_API_URL=https://api.apis.net.pe/v2
LOOKUP_API_TOKEN=
# ── Conexión pool MySQL ──
# DB_POOL_SIZE: conexiones permanentes en el pool (default 15).
#   Máx. simultáneas = pool_size + DB_MAX_OVERFLOW (default 10) = 25 por worker.
#   Con >10 usuarios concurrentes en producción aumentar a 20-25.
#   REGLA: pool_size × workers < MySQL max_connections (default 151).
#   Verificar: SHOW VARIABLES LIKE 'max_connections';
#DB_POOL_SIZE=15
#DB_MAX_OVERFLOW=10
#DB_POOL_TIMEOUT=10
#DB_POOL_RECYCLE=1800

# Opcionales (analytics en landing). El compose inyecta estos en tuwayki_landing.
GA4_MEASUREMENT_ID=
META_PIXEL_ID=
