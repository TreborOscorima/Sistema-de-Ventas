# Copiar a .env antes de "docker compose up" (obligatorio: env_file en compose).
# Con Docker: DB_USER=app (la imagen MySQL no permite root como usuario de app).
# En docker-compose, DB_HOST y REDIS_URL se sobrescriben por mysql/redis del stack.
DB_USER=app
DB_PASSWORD=your_password_here
DB_HOST=localhost
#DB_PASSWORD=admin123
#DB_HOST=tuwayki_mysql
DB_PORT=3306
DB_NAME=sistema_ventas
REDIS_URL=redis://localhost:6379/0
ALLOW_MEMORY_RATE_LIMIT_FALLBACK=1
AUTH_SECRET_KEY=replace_with_random_secret_min_32_chars #generar una clave secreta segura con python -c "import secrets; print(secrets.token_urlsafe(32))"
# Con un solo puerto (8101): http://<IP-PUBLICA>:8101/api  (luego NPM: https://tudominio.com/api)
# URL base del backend Reflex (sin /api). Dev: puerto 8000. NPM: mismo host que el frontend (ej. https://tuwayki.app).
PUBLIC_API_URL=http://localhost:8000
# URLs públicas por superficie (producción tuwayki.app). Usadas para enlaces entre landing/sys/admin.
PUBLIC_SITE_URL=https://tuwayki.app
PUBLIC_APP_URL=https://sys.tuwayki.app
PUBLIC_OWNER_URL=https://admin.tuwayki.app
ENV=prod
TRIAL_ENFORCEMENT=0
TRIAL_DAYS=15
ALLOW_DEFAULT_ADMIN=0
INITIAL_ADMIN_PASSWORD=
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_DIGIT=false
PASSWORD_REQUIRE_SPECIAL=false
RECEIPT_PAPER=80
RECEIPT_WIDTH=
# Opcionales (analytics en landing). El compose inyecta estos en tuwayki_landing.
GA4_MEASUREMENT_ID=
META_PIXEL_ID=
